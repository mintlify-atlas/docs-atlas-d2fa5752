  "keyFeatures": [
    "Type-safe functional programming with Effect, Layer, and Schema",
    "Built-in error handling with typed error channels",
    "Structured concurrency with Fibers and resource management",
    "HTTP client and server with schema validation",
    "SQL integrations for PostgreSQL, MySQL, SQL Server, and more",
    "AI/LLM integrations for Anthropic, OpenAI, and OpenRouter",
    "Observability with tracing, logging, and metrics",
    "Streaming data processing with pull-based Streams",
    "CLI application building utilities",
    "Distributed computing with cluster modules",
    "Reactive state management with Atom"
  ],
  "publicApiSurface": [
    "Effect - Core effect type and operations",
    "Layer - Dependency injection and service composition",
    "Schema - Runtime type validation and transformation",
    "Stream - Pull-based streaming data processing",
    "Array - Immutable array operations",
    "HashMap - Immutable hash map data structure",
    "HashSet - Immutable hash set data structure",
    "Option - Type-safe optional values",
    "Either - Type-safe error handling",
    "Queue - Asynchronous queue data structure",
    "PubSub - Broadcasting messages to multiple consumers",
    "Fiber - Lightweight concurrency primitive",
    "Config - Type-safe configuration management",
    "Cache - Memoization and caching utilities",
    "DateTime - Date and time operations",
    "Duration - Time duration utilities",
    "Schedule - Retry and repeat policies",
    "Cron - Cron expression parsing and scheduling",
    "HttpClient - HTTP client for external APIs",
    "HttpApi - Schema-first HTTP API building",
    "Request/RequestResolver - Batching external requests",
    "FileSystem - File system operations",
    "unstable/ai - AI/LLM integration modules",
    "unstable/cli - CLI application building",
    "unstable/cluster - Distributed computing",
    "unstable/sql - SQL query building and execution",
    "unstable/process - Child process management"
  ]
